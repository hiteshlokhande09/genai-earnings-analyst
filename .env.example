# Copy this file to ".env" and fill in your values.
# The .env file is git-ignored and must never be committed.

# --- Llama 3 (Groq free tier by default) ---
# Get a free key at https://console.groq.com/keys
LLAMA3_API_KEY=gsk_your_groq_api_key_here
LLAMA3_BASE_URL=https://api.groq.com/openai/v1/chat/completions
LLAMA3_MODEL=llama-3.1-8b-instant

# --- SEC EDGAR ---
# The SEC requires a descriptive User-Agent with your name and email.
SEC_USER_AGENT=Your Name your.email@example.com
